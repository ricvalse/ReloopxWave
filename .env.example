# Copy to .env and fill in. Never commit .env.

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Local Supabase CLI default. For Railway + cloud Supabase, use the Supavisor
# POOLER URL (session mode, port 5432), not the direct db.<ref>.supabase.co
# endpoint — the direct endpoint is IPv6-only and Railway can't reach it.
# Pooler format:
#   postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# ---- Redis (local) ----
REDIS_URL=redis://localhost:6379/0

# ---- OpenAI / Anthropic ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_ENABLED=false

# ---- Integrations ----
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=

# Wave Marketing operates as a single 360dialog Partner — every merchant's
# WhatsApp number is a channel under that one partnership. The API key is
# used for outbound sends; the Partner ID keys the autonomous channel-
# creation flow (Partner Hub admin API).
WHATSAPP_PARTNER_API_KEY=
WHATSAPP_PARTNER_ID=

# ---- Encryption (AES-256-GCM KEK for integrations table) ----
# Generate with:
#   uv run python -c "from shared.crypto import generate_kek_base64; print(generate_kek_base64())"
# Must decode to exactly 32 bytes. Losing this key means all encrypted
# integration secrets are unrecoverable — back it up.
INTEGRATIONS_KEK_BASE64=

# ---- Observability ----
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
POSTHOG_KEY=

# ---- Frontend (Next.js) ----
# NEXT_PUBLIC_* values are inlined into the browser bundle at build time —
# rotating them requires a frontend rebuild. Set these on each Railway web
# service (web-admin, web-merchant) so they're available as Docker build args.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# ---- Runtime ----
ENVIRONMENT=local
LOG_LEVEL=info
