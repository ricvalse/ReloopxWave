# Copy to .env and fill in. Never commit .env.

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# ---- Redis (local) ----
REDIS_URL=redis://localhost:6379/0

# ---- OpenAI / Anthropic ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_ENABLED=false

# ---- Integrations ----
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# ---- Encryption (AES-256-GCM KEK for integrations table) ----
# Generate with:
#   uv run python -c "from shared.crypto import generate_kek_base64; print(generate_kek_base64())"
# Must decode to exactly 32 bytes. Losing this key means all encrypted
# integration secrets are unrecoverable — back it up.
INTEGRATIONS_KEK_BASE64=

# ---- Observability ----
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
POSTHOG_KEY=

# ---- Runtime ----
ENVIRONMENT=local
LOG_LEVEL=info
