# Shared ignore for every Dockerfile in this repo (backend api+worker,
# frontend web-admin+web-merchant). A single file keeps backend and frontend
# Docker builds consistent; contexts can be narrowed per-Dockerfile later if
# upload size ever becomes a real concern.

# ---- Git / editors ----
.git
.github
.vscode
.idea

# ---- Docs + design files ----
docs/
*.md
!backend/README.md
!frontend/README.md

# ---- Local env files ----
.env
.env.*
!.env.example

# ---- Python build / test caches ----
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.venv/
**/.coverage
**/htmlcov/

# ---- Node build artifacts (always re-installed in builder stage) ----
**/node_modules/
**/.next/
**/.turbo/
**/.vercel/
**/dist/
**/build/
**/out/
**/*.tsbuildinfo
**/.eslintcache

# ---- OS ----
.DS_Store
